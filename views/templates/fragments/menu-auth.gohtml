{{if .HasIdentity -}}
<li>
    <a href="{{path "profile"}}">
        <img src="{{.User.Avatar 32}}" alt="avatar"/>
        <span>Профиль</span>
    </a>
</li>
{{if .IsAdmin }}
    <li>
        <a href="/admin">
            <span class="glyphicon glyph-fw glyphicon-cog"></span>
            <span>Админка</span>
        </a>
    </li>
{{end}}
{{- end}}
